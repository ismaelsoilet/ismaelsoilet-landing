            </ul>
          </div>
          <Button variant={idx === 1 ? 'cyber' : 'outline'} class="w-full font-bold" href="/contato">
            Contratar {tier.name}
          </Button>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Mid-page CTA -->
  <Section class="bg-indigo-600 dark:bg-indigo-950 text-white rounded-3xl my-16 px-8 py-12 md:py-16 md:px-12 relative overflow-hidden scroll-reveal opacity-0" container={true}>
