    </div>
  </Section>

  <!-- FAQ (Accordion) -->
  <Section id="faq" class="bg-slate-50 dark:bg-slate-950 border-t border-slate-200/5 dark:border-slate-900">
    <div class="text-center max-w-3xl mx-auto flex flex-col gap-4 mb-16 scroll-reveal opacity-0">
