---
import { getEntry } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';

const entry = await getEntry('legal', 'termos');
if (!entry) {
  return Astro.redirect('/404');
}

const { lastUpdated, sections } = entry.data;
---

<PageLayout 
  title="Termos de Uso" 
  description="Consulte os Termos de Uso da Suitplus. Conheça as regras e diretrizes para a navegação em nossa plataforma comercial."
  noindex={true}
>
  <Section class="max-w-4xl mx-auto py-12 md:py-20">
    <header class="border-b border-slate-200/10 dark:border-slate-900 pb-6 mb-10">
      <h1 class="text-3xl md:text-5xl font-black tracking-tight text-slate-900 dark:text-white mb-2">
        Termos de Uso
      </h1>
      <p class="text-sm text-slate-500 dark:text-slate-400">
        Última atualização: <time datetime={new Date(lastUpdated).toISOString()}>
          {new Date(lastUpdated).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </p>
    </header>

    <div class="flex flex-col gap-8 text-slate-700 dark:text-slate-300 leading-relaxed">
      {sections.map(section => (
        <div class="flex flex-col gap-3">
          <h2 class="text-xl font-bold text-slate-950 dark:text-white">{section.heading}</h2>
          <p class="text-sm md:text-base">{section.body}</p>
        </div>
      ))}
    </div>
  </Section>
</PageLayout>
