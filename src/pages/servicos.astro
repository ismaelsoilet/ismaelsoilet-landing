---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { buildServiceSchema, buildFaqSchema } from '../lib/seo';

// Fetch Services collection
const allServices = await getCollection('services');
const serviceData = allServices.find(s => s.id === 'marketing-digital');
const pricingTiers = serviceData ? serviceData.data.tiers : [];

// Fetch FAQs collection
const faqs = await getCollection('faqs');
const faqSchema = buildFaqSchema(faqs.map(f => ({ question: f.data.question, answer: f.data.answer })));

// Map to ServiceItem schema format
const serviceItems = pricingTiers.map(t => ({
  name: `Plano ${t.name} - ${serviceData?.data.name}`,
  description: `Aceleração digital com features do tier ${t.name}.`,
  price: t.price
}));

const serviceSchema = buildServiceSchema(serviceItems);
---

<PageLayout 
  title="Nossos Serviços" 
  description="Confira os planos de aceleração digital e soluções de marketing corporativo da Suitplus. Escolha entre nossos tiers Bronze, Gold e Platinum."
>
  <!-- Inject Service and FAQ Schemas -->
  <JsonLd schema={serviceSchema} />
  <JsonLd schema={faqSchema} />

  <!-- Hero Section -->
  <Section class="pt-8 pb-16 bg-radial from-slate-900 via-slate-950 to-slate-950 text-slate-100 border-b border-slate-200/5 dark:border-slate-900">
    <div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
      <Badge variant="warning" class="self-center">Planos e Escala</Badge>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight">
        Estruturas sob medida para o seu <span class="bg-gradient-to-r from-cyan-400 to-indigo-500 bg-clip-text text-transparent">crescimento</span>
      </h1>
      <p class="text-lg text-slate-400 leading-relaxed">
        Oferecemos três níveis de serviço focados em velocidade, conversão e estabilidade, com SLAs estritos e suporte técnico dedicado.
      </p>
    </div>
  </Section>

  <!-- Detailed Plans Grid -->
  <Section class="bg-white dark:bg-slate-900/20 border-b border-slate-200/5 dark:border-slate-900">
    <div class="grid md:grid-cols-3 gap-8 items-stretch">
      {pricingTiers.map((tier, idx) => (
        <Card class={`flex flex-col justify-between p-8 border ${idx === 1 ? 'border-indigo-500 dark:border-indigo-400 shadow-2xl relative' : 'border-slate-200 dark:border-slate-800'} bg-white dark:bg-slate-900/30`}>
          {idx === 1 && (
            <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-3.5 py-1 text-xs font-bold uppercase tracking-wider text-white bg-indigo-600 rounded-full">
              Mais Recomendado
            </span>
          )}
          <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">{tier.name}</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Solução recomendada para operações em crescimento e consolidação.</p>
            
            <div class="flex items-baseline gap-1 my-6 border-y border-slate-100 dark:border-slate-800/40 py-4">
              <span class="text-4xl font-black text-slate-900 dark:text-white">{tier.price}</span>
            </div>

            <ul class="flex flex-col gap-3.5 text-sm text-slate-600 dark:text-slate-400 mb-8">
              {tier.features.map(feat => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-emerald-500 shrink-0"><use href="/icons/sprite.svg#icon-check" /></svg>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
          </div>
          <Button variant={idx === 1 ? 'cyber' : 'outline'} class="w-full" href="/contato">
            Contratar Plano {tier.name}
          </Button>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Deliverables Checklist Section -->
  <Section class="bg-slate-50 dark:bg-slate-950">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="flex flex-col gap-6">
        <Badge variant="success" class="self-start">Garantia de Qualidade</Badge>
        <h2 class="text-3xl font-extrabold tracking-tight">O que está incluído em toda entrega?</h2>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-sm md:text-base">
          Independente do plano escolhido, nossa equipe de engenharia aplica padrões de excelência de nível internacional para garantir que o seu projeto atinja notas máximas e segurança corporativa absoluta.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm text-slate-600 dark:text-slate-400">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-500"><use href="/icons/sprite.svg#icon-check" /></svg>
            <span>Certificado SSL Grátis</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-500"><use href="/icons/sprite.svg#icon-check" /></svg>
            <span>Compressão Brotli/Gzip</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-500"><use href="/icons/sprite.svg#icon-check" /></svg>
            <span>Otimização Web Vitals</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-500"><use href="/icons/sprite.svg#icon-check" /></svg>
            <span>Segurança CSP e HSTS</span>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="absolute inset-0 bg-indigo-500/5 rounded-2xl blur-2xl" aria-hidden="true"></div>
        <div class="relative border border-slate-200/10 dark:border-slate-800 p-8 rounded-2xl bg-white dark:bg-slate-900/30">
          <h3 class="font-bold text-lg mb-4">Garantia de Uptime</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6">
            Nossos servidores de borda (edge) distribuídos globalmente garantem que a sua landing page continue online mesmo sob tráfego massivo. Monitoramos a integridade a cada minuto com relatórios em tempo real.
          </p>
          <div class="flex items-center gap-3">
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 uppercase tracking-wider">Todos os Sistemas Operacionais</span>
          </div>
        </div>
      </div>
    </div>
  </Section>
</PageLayout>
