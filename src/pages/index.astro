    <!-- CONTACT CTA & FORM -->
    <section id="contact" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-slate-50 dark:bg-slate-900/10 reveal">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Iniciar um Projeto</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4">Entre em contato para consultorias de desburocratização, engenharia de software ou parcerias estratégicas.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          <!-- Direct Channels -->
          <div class="md:col-span-1 flex flex-col gap-4">
            <a href={`mailto:${site.contact.email}`} class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30 p-6 flex flex-col gap-2 hover:border-cyber-500/20 transition">
              <svg class="w-6 h-6 text-cyber-600 dark:text-cyber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <span class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">E-mail</span>
              <span class="text-sm font-bold text-slate-900 dark:text-white break-all">{site.contact.email}</span>
            </a>

            <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30 p-6 flex flex-col gap-2 hover:border-emerald-500/20 transition">
              <svg class="w-6 h-6 text-emerald-500 dark:text-emerald-400"><use href="/icons/sprite.svg#icon-whatsapp-logo" /></svg>
              <span class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">WhatsApp</span>
              <span class="text-sm font-bold text-slate-900 dark:text-white">{site.contact.phone}</span>
            </a>
          </div>

          <!-- Contact Form with Honeypot -->
          <GlassCard class="md:col-span-2 rounded-3xl border border-slate-200 dark:border-slate-800 p-8">
            <form id="contact-form" action={site.webhook.contact} method="POST" class="flex flex-col gap-4">
              <!-- Honeypot Field for Spam Prevention (Hidden visually but available to bots) -->
              <div class="absolute -left-[9999px] h-0 overflow-hidden" tabindex="-1">
                <label for="honeypot_field">Se você é humano, deixe este campo em branco</label>
                <input type="text" id="honeypot_field" name="honeypot_field" tabindex="-1" autocomplete="off" />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label for="name" class="text-xs font-bold text-slate-600 dark:text-slate-400 uppercase tracking-wider">Nome</label>
                  <input type="text" id="name" name="name" required class="px-4 py-3 rounded-lg bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-slate-200 text-sm focus:outline-none focus:border-cyber-500 transition" placeholder="Seu nome" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="email" class="text-xs font-bold text-slate-600 dark:text-slate-400 uppercase tracking-wider">E-mail</label>
                  <input type="email" id="email" name="email" required class="px-4 py-3 rounded-lg bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-slate-200 text-sm focus:outline-none focus:border-cyber-500 transition" placeholder="seu@email.com" />
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="message" class="text-xs font-bold text-slate-600 dark:text-slate-400 uppercase tracking-wider">Mensagem</label>
                <textarea id="message" name="message" required rows="4" class="px-4 py-3 rounded-lg bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-slate-200 text-sm focus:outline-none focus:border-cyber-500 transition" placeholder="Como posso ajudar você?"></textarea>
              </div>

              <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-cyber-500 to-primary-600 hover:from-cyber-600 hover:to-primary-700 text-white font-bold rounded-lg shadow-lg shadow-cyber-500/10 transition active:scale-[0.99] flex items-center justify-center gap-2">
                Enviar Mensagem
                <svg class="w-4 h-4"><use href="/icons/sprite.svg#icon-arrow-right" /></svg>
              </button>
            </form>
            <div id="form-feedback" class="mt-4 text-sm text-center font-bold hidden"></div>
          </GlassCard>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<!-- CUSTOM SCOPED STYLE FOR PREMIUM AESTHETIC (dark-default, light-aware) -->
<style is:global>
  /* 3D animate hero radial background */
  .hero-bg {
    background:
      radial-gradient(ellipse 60% 40% at 30% 20%, rgba(6, 182, 212, 0.10), transparent),
      radial-gradient(ellipse 50% 50% at 70% 80%, rgba(217, 119, 6, 0.08), transparent),
      var(--color-slate-50);
    background-size: 200% 200%;
    animation: gradientShift 15s ease infinite;
  }
  html.dark .hero-bg {
    background:
      radial-gradient(ellipse 60% 40% at 30% 20%, rgba(6, 182, 212, 0.15), transparent),
      radial-gradient(ellipse 50% 50% at 70% 80%, rgba(217, 119, 6, 0.12), transparent),
      var(--color-navy);
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50% }
    50% { background-position: 100% 50% }
    100% { background-position: 0% 50% }
  }

  .animate-spin-slow {
    animation: spin 8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Animated Role Ticker */
  .ticker-wrapper {
    mask-image: linear-gradient(to bottom, transparent, white 20%, white 80%, transparent);
    overflow: hidden;
  }

  .ticker-track {
    animation: ticker 15s cubic-bezier(0.76, 0, 0.24, 1) infinite;
  }

  @keyframes ticker {
    0%, 15% { transform: translateY(0); }
    20%, 35% { transform: translateY(-20%); }
    40%, 55% { transform: translateY(-40%); }
    60%, 75% { transform: translateY(-60%); }
    80%, 95% { transform: translateY(-80%); }
    100% { transform: translateY(0); }
  }

  .animate-pulse-slow {
    animation: pulseSlow 6s ease-in-out infinite;
  }

  @keyframes pulseSlow {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  /* Scroll-driven Reveal Animations */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .reveal {
        animation: revealUp 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 5% entry 30%;
      }
    }
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Accessibility: prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-delay: 0s !important;
      animation-duration: 0s !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0s !important;
      scroll-behavior: auto !important;
    }
    .ticker-track {
      animation: none !important;
    }
    .hero-bg {
      animation: none !important;
    }
  }
</style>

<script>
  // Simple Counter Animation trigger
  function animateCounters() {
    const cards = document.querySelectorAll('.metric-card');
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const options = {
      threshold: 0.2,
      rootMargin: '0px'
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const numberEl = entry.target.querySelector('[data-target]');
          if (numberEl) {
            const target = parseInt(numberEl.getAttribute('data-target') || '0', 10);
            
            if (prefersReducedMotion) {
              // Set final value immediately
              if (target === 350000) numberEl.textContent = '350.000+';
              else if (target === 300000) numberEl.textContent = 'R$ 300K/ano';
              else if (target === 25000) numberEl.textContent = 'R$ 25K/mês';
              else if (target === 78) numberEl.textContent = '78%';
            } else {
              let count = 0;
              const duration = 1500; // ms
              const stepTime = 16; // ms (approx 60fps)
              const steps = duration / stepTime;
              const increment = target / steps;

              const timer = setInterval(() => {
                count += increment;
                if (count >= target) {
                  clearInterval(timer);
                  // Final formats
                  if (target === 350000) numberEl.textContent = '350.000+';
                  else if (target === 300000) numberEl.textContent = 'R$ 300K/ano';
                  else if (target === 25000) numberEl.textContent = 'R$ 25K/mês';
                  else if (target === 78) numberEl.textContent = '78%';
                } else {
                  if (target === 350000) {
                    numberEl.textContent = Math.floor(count).toLocaleString('pt-BR') + '+';
                  } else if (target === 300000 || target === 25000) {
                    numberEl.textContent = 'R$ ' + Math.floor(count).toLocaleString('pt-BR');
                  } else {
                    numberEl.textContent = Math.floor(count) + '%';
                  }
                }
              }, stepTime);
            }
          }
          observer.unobserve(entry.target);
        }
      });
    }, options);

    cards.forEach(card => observer.observe(card));
  }

  // Handle Form Submission via Webhook
  function handleFormSubmission() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const feedback = document.getElementById('form-feedback');
    if (!form || !feedback) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // HoneyPot check
      const honeypot = (document.getElementById('honeypot_field') as HTMLInputElement)?.value;
      if (honeypot) {
        console.warn('Spam detected via honeypot.');
        feedback.textContent = 'Mensagem enviada com sucesso (filtro anti-spam ativo).';
        feedback.className = 'mt-4 text-sm text-center font-bold text-emerald-600 dark:text-emerald-400 block';
        form.reset();
        return;
      }

      feedback.textContent = 'Enviando...';
      feedback.className = 'mt-4 text-sm text-center font-bold text-cyber-600 dark:text-cyber-400 block';

      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          feedback.textContent = 'Mensagem enviada com sucesso! Em breve entrarei em contato.';
          feedback.className = 'mt-4 text-sm text-center font-bold text-emerald-600 dark:text-emerald-400 block';
          form.reset();
        } else {
          throw new Error('Falha no envio.');
        }
      } catch (err) {
        feedback.textContent = 'Erro ao enviar mensagem. Por favor, utilize o WhatsApp ou e-mail.';
        feedback.className = 'mt-4 text-sm text-center font-bold text-red-600 dark:text-red-400 block';
      }
    });
  }

  // Bind JS on Astro transitions and initial load
  document.addEventListener('astro:page-load', () => {
    animateCounters();
    handleFormSubmission();
  });
</script>
