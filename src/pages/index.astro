  <script is:inline>
    // Lógica interativa da Home portadas de main.js
    document.addEventListener('astro:page-load', () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Spotlight effect para os cards
      document.querySelectorAll(".glass-card").forEach(card => {
        card.onmousemove = e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        };
      });


      // Scroll Reveal
      if (!prefersReducedMotion) {
        if (!window.__revealObserver) {
          const observerOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
          window.__revealObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-in-up');
                entry.target.classList.remove('opacity-0', 'scroll-reveal');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);
        }
        document.querySelectorAll('.scroll-reveal').forEach(el => {
          window.__revealObserver.observe(el);
          if (el.getBoundingClientRect().top < window.innerHeight) {
            el.classList.add('animate-fade-in-up');
            el.classList.remove('opacity-0', 'scroll-reveal');
            window.__revealObserver.unobserve(el);
          }
        });
      } else {
        document.querySelectorAll('.scroll-reveal').forEach(el => {
          el.classList.remove('opacity-0', 'scroll-reveal');
        });
      }

      // Solutions Carousel
      const initSolutionsCarousel = () => {
        const carousel = document.getElementById("solutions-carousel");
        if (!carousel) return;
        const tabs = carousel.querySelectorAll(".solutions-tab");
        const switchTab = (targetSystem) => {
          tabs.forEach(tab => {
            const isActive = tab.dataset.system === targetSystem;
            tab.classList.toggle("active", isActive);
            tab.setAttribute("aria-selected", isActive ? "true" : "false");
          });
          carousel.querySelectorAll(".solutions-panel").forEach(panel => {
            if (panel.dataset.system === targetSystem) {
              panel.classList.remove("hidden");
            } else {
              panel.classList.add("hidden");
            }
          });
        };
        const tabList = carousel.querySelector('[role="tablist"]');
        if (tabList) {
          tabList.addEventListener("click", (e) => {
            const tab = e.target.closest(".solutions-tab");
            if (!tab) return;
            switchTab(tab.dataset.system);
            if (window.innerWidth < 1024) {
              const container = carousel.querySelector('.solutions-tabs-container');
              if (container) {
                const scrollLeft = tab.offsetLeft - (container.clientWidth / 2) + (tab.clientWidth / 2);
                container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
              }
            }
          });
        }
      };

      // Epicentro Carousel
      const initEpicentroCarousel = () => {
        const carousel = document.getElementById("epicentro-carousel");
        if (!carousel) return;
        const tabs = carousel.querySelectorAll(".epicentro-tab");
        const switchTab = (targetPanel) => {
          tabs.forEach(tab => {
            const isActive = tab.dataset.target === targetPanel;
            tab.classList.toggle("active", isActive);
            tab.setAttribute("aria-selected", isActive ? "true" : "false");
          });
          carousel.querySelectorAll(".epicentro-panel").forEach(panel => {
            if (panel.dataset.panel === targetPanel) {
              panel.classList.remove("hidden");
            } else {
              panel.classList.add("hidden");
            }
          });
        };
        const tabList = carousel.querySelector('[role="tablist"]');
        if (tabList) {
          tabList.addEventListener("click", (e) => {
            const tab = e.target.closest(".epicentro-tab");
            if (!tab) return;
            switchTab(tab.dataset.target);
            if (window.innerWidth < 1024) {
              const container = carousel.querySelector('.epicentro-tabs-container');
              if (container) {
                const scrollLeft = tab.offsetLeft - (container.clientWidth / 2) + (tab.clientWidth / 2);
                container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
              }
            }
          });
        }
      };

      // FAQ Accordion
      const initFaqAccordion = () => {
        document.querySelectorAll(".faq-item").forEach(item => {
          const questionBtn = item.querySelector(".faq-question");
          if (!questionBtn) return;
          const newQuestionBtn = questionBtn.cloneNode(true);
          questionBtn.parentNode.replaceChild(newQuestionBtn, questionBtn);
          newQuestionBtn.addEventListener("click", () => {
            const isCurrentlyOpen = item.classList.contains("open");
            document.querySelectorAll(".faq-item").forEach(otherItem => {
              otherItem.classList.remove("open");
              otherItem.querySelector(".faq-question").setAttribute("aria-expanded", "false");
            });
            if (!isCurrentlyOpen) {
              item.classList.add("open");
              newQuestionBtn.setAttribute("aria-expanded", "true");
            }
          });
        });
      };

      initSolutionsCarousel();
      initEpicentroCarousel();
      initFaqAccordion();
    });
  </script>
