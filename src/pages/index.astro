---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { buildPersonSchema } from '../lib/seo';
import { site } from '../content/site';

// Import real profile photos and case assets uploaded by the user
import profilePhoto from '../assets/ISMAEL PERFIL_COMPLETA.png';
import codingPhoto from '../assets/ismael-codificando.png';
import notebookPhoto from '../assets/ismael-notebook.png';
import futurePhoto from '../assets/ismael-observando-futuro.png';

const personSchema = buildPersonSchema();
---

<BaseLayout 
  title="Ismael Soilet | Product Owner, Developer & Gestor Público" 
  description="Portfolio profissional de Ismael Hosni Soilet de Lima. Especialista em Transformação Digital, Ciência de Dados, Gestão Estratégica e Criador do FiscalizaPlus."
>
  {personSchema && <JsonLd schema={personSchema} />}

  <div class="home-wrapper">
    <!-- HERO SECTION -->
    <section id="hero" class="hero-section flex items-center justify-center relative overflow-hidden min-h-[90vh]">
      <div class="hero-bg absolute inset-0 -z-10"></div>
      <div class="hero-glow absolute w-[500px] h-[500px] rounded-full bg-cyber-500/10 blur-[120px] top-1/4 left-1/4 animate-pulse"></div>
      <div class="hero-glow absolute w-[400px] h-[400px] rounded-full bg-primary-500/10 blur-[100px] bottom-1/4 right-1/4 animate-pulse-slow"></div>

      <div class="max-w-5xl mx-auto px-6 py-20 text-center flex flex-col items-center gap-8 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-cyber-500/30 bg-cyber-500/5 text-cyber-600 dark:text-cyber-400 text-xs font-semibold tracking-wider uppercase animate-fade-in">
          <svg class="w-3.5 h-3.5 animate-spin-slow" aria-hidden="true"><use href="/icons/sprite.svg#icon-sparkle" /></svg>
          Tecnologia & Gestão Pública
        </div>

        <h1 class="text-5xl md:text-8xl font-black tracking-tight leading-none uppercase text-slate-900 dark:text-white">
          <span class="bg-gradient-to-r from-cyber-400 via-teal-300 to-primary-400 bg-clip-text text-transparent">
            Ismael Soilet
          </span>
        </h1>

        <div class="ticker-wrapper h-12 overflow-hidden flex items-center justify-center text-xl md:text-3xl font-bold text-slate-700 dark:text-slate-300">
          <div class="ticker-track">
            {site.person?.roles.map((role) => (
              <div class="ticker-item py-1">{role}</div>
            ))}
          </div>
        </div>

        <p class="max-w-2xl text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed font-medium">
          Transformo regras de negócio complexas em soluções digitais de alto impacto. Unindo Tecnologia da Informação, Ciência de Dados e Gestão Estratégica para gerar economia milionária e desburocratização.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-4">
          <a href="#about" class="px-8 py-4 bg-gradient-to-r from-cyber-500 to-primary-600 hover:from-cyber-600 hover:to-primary-700 text-white font-bold rounded-xl shadow-lg shadow-cyber-500/10 transition duration-300 active:scale-95 text-center">
            Conhecer Trajetória
          </a>
          <a href="#contact" class="px-8 py-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 text-slate-700 dark:text-slate-200 font-bold rounded-xl transition duration-300 active:scale-95 text-center backdrop-blur-sm">
            Entrar em Contato
          </a>
        </div>

        <div class="scroll-indicator absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce cursor-pointer">
          <a href="#about" aria-label="Rolar para baixo">
            <svg class="w-6 h-6 text-slate-400 dark:text-slate-500 hover:text-cyber-600 dark:hover:text-cyber-400 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT BENTO GRID -->
    <section id="about" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-slate-50 dark:bg-slate-950/20 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Perfil Multidisciplinar</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Uma combinação estratégica de competências para resolver problemas complexos em grande escala.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Photo Card -->
          <div class="md:row-span-2 rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800/80 bg-slate-100 dark:bg-slate-900/40 backdrop-blur-md relative group">
            <Image src={profilePhoto} alt="Ismael Soilet" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent p-6 flex flex-col justify-end">
              <span class="text-xs font-semibold text-cyber-400 uppercase tracking-widest mb-1">Origem</span>
              <h3 class="text-xl font-bold text-white">Peruíbe - SP, Brasil</h3>
            </div>
          </div>

          <!-- Bio Narrative Card -->
          <GlassCard class="md:col-span-2 rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <div>
              <span class="text-xs font-semibold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest block mb-4">Minha História</span>
              <h3 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">Como Gestor, Desenvolvedor, Líder e Empreendedor</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                Minha história é abrangente e repleta de desafios superados. Atuo integrando a liderança de equipes com a escrita de códigos e análise de dados para transformar governos e organizações. Lidero iniciativas paperless, modernização tributária e desenvolvimento de softwares de estado da arte para desatar nós burocráticos.
              </p>
            </div>
            <div class="flex flex-wrap gap-3">
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Liderança de TI</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Desenvolvimento Backend</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Data Science</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Governança Pública</span>
            </div>
          </GlassCard>

          <!-- Quote Card -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <svg class="w-8 h-8 text-cyber-500/40 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-4.765 2.627-5.023 5.424.301-.15.688-.225 1.054-.225 1.761 0 3.208 1.447 3.208 3.208.001 1.761-1.447 3.208-3.208 3.208-1.76 0-3.023-1.189-3.023-3.208v-1.558c0-3.328 1.956-6.113 4.542-7.505l-.995-2.151C14.07 4.908 9.571 8.8 9.571 14.156v6.844h4.446zm-10 0v-7.391c0-5.704 3.73-9.57 8.983-10.609l.994 2.151c-2.432.917-4.764 2.627-5.023 5.424.302-.15.688-.225 1.054-.225 1.761 0 3.208 1.447 3.208 3.208.001 1.761-1.447 3.208-3.208 3.208-1.76 0-3.024-1.189-3.024-3.208v-1.558c0-3.328 1.956-6.113 4.542-7.505l-.995-2.151C4.07 4.908.571 8.8.571 14.156v6.844h4.446z"/></svg>
            <p class="text-slate-700 dark:text-slate-300 font-medium italic text-lg leading-relaxed mb-4">
              "Construo ecossistemas ágeis que desburocratizam serviços, aumentam a performance da equipe e geram economia milionária."
            </p>
            <span class="text-xs text-slate-600 dark:text-slate-500 font-bold uppercase tracking-wider">— Filosofia de Trabalho</span>
          </GlassCard>

          <!-- Experience Card -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <span class="text-xs font-semibold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest block mb-4">Tempo</span>
            <div class="flex items-baseline gap-2">
              <span class="text-6xl font-black text-slate-900 dark:text-white bg-gradient-to-r from-cyber-400 to-primary-400 bg-clip-text text-transparent">10+</span>
              <span class="text-lg font-bold text-slate-700 dark:text-slate-300">Anos</span>
            </div>
            <p class="text-slate-600 dark:text-slate-400 mt-2 text-sm leading-relaxed">
              De experiência atuando como elo estratégico entre equipes técnicas e regras de negócio complexas de administração pública.
            </p>
          </GlassCard>
        </div>
      </div>
    </section>

    <!-- IMPACT DASHBOARD -->
    <section id="impact" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-white dark:bg-slate-900/10 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Retorno de Investimento (ROI)</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Resultados tangíveis e economia direta gerada por meio de liderança tecnológica e inovação estratégica.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Metric Card 1 -->
          <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between relative group hover:border-cyber-500/30">
            <div>
              <div class="text-sm font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-500 mb-2">Paperless</div>
              <div class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-2 tracking-tight group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="350000">0</div>
            </div>
            <div class="mt-4">
              <div class="text-sm font-bold text-slate-900 dark:text-slate-200 mb-1">Processos Digitais</div>
              <p class="text-xs text-slate-600 dark:text-slate-500 leading-relaxed">Legado físico de 350.000 processos migrado com sucesso para formato digital.</p>
            </div>
          </GlassCard>

          <!-- Metric Card 2 -->
          <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between relative group hover:border-cyber-500/30">
            <div>
              <div class="text-sm font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-500 mb-2">IPTU & ISS</div>
              <div class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-2 tracking-tight group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="300000">R$ 0</div>
            </div>
            <div class="mt-4">
              <div class="text-sm font-bold text-slate-900 dark:text-slate-200 mb-1">Economia / Ano</div>
              <p class="text-xs text-slate-600 dark:text-slate-500 leading-relaxed">Graças à implantação do IPTU e ISS 100% digitais e Portal Cidadão.</p>
            </div>
          </GlassCard>

          <!-- Metric Card 3 -->
          <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between relative group hover:border-cyber-500/30">
            <div>
              <div class="text-sm font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-500 mb-2">FiscalizaPlus</div>
              <div class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-2 tracking-tight group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="25000">R$ 0</div>
            </div>
            <div class="mt-4">
              <div class="text-sm font-bold text-slate-900 dark:text-slate-200 mb-1">Economia / Mês</div>
              <p class="text-xs text-slate-600 dark:text-slate-500 leading-relaxed">Redução direta de custos com licença de softwares de terceiros.</p>
            </div>
          </GlassCard>

          <!-- Metric Card 4 -->
          <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between relative group hover:border-cyber-500/30">
            <div>
              <div class="text-sm font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-500 mb-2">Eficiência</div>
              <div class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-2 tracking-tight group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="78">0%</div>
            </div>
            <div class="mt-4">
              <div class="text-sm font-bold text-slate-900 dark:text-slate-200 mb-1">Aumento de Capacidade</div>
              <p class="text-xs text-slate-600 dark:text-slate-500 leading-relaxed">Escala de 18k para 32k processos anuais sem aumentar funcionários.</p>
            </div>
          </GlassCard>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES (PROJECTS) -->
    <section id="projects" class="py-24 border-t border-slate-200 dark:border-slate-900 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Casos de Sucesso</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Projetos reais detalhados através do formato clássico de Desafio, Solução e Impacto gerado.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Case 1: FiscalizaPlus -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 group">
            <div class="h-64 overflow-hidden relative">
              <Image src={codingPhoto} alt="FiscalizaPlus Codificando" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
              <div class="absolute inset-0 bg-slate-950/70 p-6 flex flex-col justify-between">
                <span class="px-3 py-1 rounded bg-cyber-500/20 text-cyber-600 dark:text-cyber-400 text-xs font-bold self-start uppercase tracking-wider">Inovação em Produto</span>
                <span class="text-2xl font-black text-white">FiscalizaPlus</span>
              </div>
            </div>
            <div class="p-8 flex-grow flex flex-col justify-between">
              <div class="flex flex-col gap-4">
                <div>
                  <h4 class="text-sm font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-1">Desafio</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Custo recorrente de R$ 25.000 mensais com licenças de softwares terceirizados ineficientes na fiscalização tributária.</p>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-primary-600 dark:text-primary-400 uppercase tracking-widest mb-1">Solução</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Liderança e desenvolvimento de software próprio customizado, orquestrado e integrado para a fiscalização da fazenda pública municipal.</p>
                </div>
              </div>
              <div class="mt-6 pt-6 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                <span class="text-xs text-slate-600 dark:text-slate-500 uppercase tracking-wider font-bold">Impacto Direto</span>
                <span class="text-lg font-black text-slate-900 dark:text-white">R$ 25.000 / mês salvos</span>
              </div>
            </div>
          </GlassCard>

          <!-- Case 2: Paperless Peruíbe -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 group">
            <div class="h-64 overflow-hidden relative">
              <Image src={notebookPhoto} alt="Processos Digitais" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
              <div class="absolute inset-0 bg-slate-950/70 p-6 flex flex-col justify-between">
                <span class="px-3 py-1 rounded bg-primary-500/20 text-primary-600 dark:text-primary-400 text-xs font-bold self-start uppercase tracking-wider">Desburocratização</span>
                <span class="text-2xl font-black text-white">Paperless (Prefeitura de Peruíbe)</span>
              </div>
            </div>
            <div class="p-8 flex-grow flex flex-col justify-between">
              <div class="flex flex-col gap-4">
                <div>
                  <h4 class="text-sm font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-1">Desafio</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Um legado de 350.000 processos físicos que geravam gastos com sulfite, logística, arquivos físicos e limitação de processamento anual.</p>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-primary-600 dark:text-primary-400 uppercase tracking-widest mb-1">Solução</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Liderança estratégica para a migração para processos 100% digitais, eliminando o papel e desburocratizando as rotinas públicas.</p>
                </div>
              </div>
              <div class="mt-6 pt-6 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                <span class="text-xs text-slate-600 dark:text-slate-500 uppercase tracking-wider font-bold">Resultado</span>
                <span class="text-lg font-black text-slate-900 dark:text-white">+78% Capacidade de Processamento</span>
              </div>
            </div>
          </GlassCard>

          <!-- Case 3: IPTU e ISS 100% Digitais -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 group">
            <div class="h-64 overflow-hidden relative">
              <div class="absolute inset-0 bg-gradient-to-br from-primary-950/80 to-slate-950 p-6 flex flex-col justify-between">
                <span class="px-3 py-1 rounded bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-xs font-bold self-start uppercase tracking-wider">Eficiência Tributária</span>
                <span class="text-2xl font-black text-white">IPTU & ISS Digitais + Portal Cidadão</span>
              </div>
            </div>
            <div class="p-8 flex-grow flex flex-col justify-between">
              <div class="flex flex-col gap-4">
                <div>
                  <h4 class="text-sm font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-1">Desafio</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Custos altos e burocracia desnecessária no envio físico de carnês de tributos e atendimento presencial lento.</p>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-primary-600 dark:text-primary-400 uppercase tracking-widest mb-1">Solução</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Desenvolvimento e coordenação do Portal Cidadão com emissões e pagamentos em ambiente seguro 100% online.</p>
                </div>
              </div>
              <div class="mt-6 pt-6 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                <span class="text-xs text-slate-600 dark:text-slate-500 uppercase tracking-wider font-bold">Impacto</span>
                <span class="text-lg font-black text-slate-900 dark:text-white">R$ 300.000 / ano economizados</span>
              </div>
            </div>
          </GlassCard>

          <!-- Case 4: E-SUS Saúde Digital -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 group">
            <div class="h-64 overflow-hidden relative">
              <Image src={futurePhoto} alt="E-SUS Saúde" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
              <div class="absolute inset-0 bg-slate-950/70 p-6 flex flex-col justify-between">
                <span class="px-3 py-1 rounded bg-cyber-500/20 text-cyber-600 dark:text-cyber-400 text-xs font-bold self-start uppercase tracking-wider">Saúde Digital</span>
                <span class="text-2xl font-black text-white">Implantação E-SUS Custo Zero</span>
              </div>
            </div>
            <div class="p-8 flex-grow flex flex-col justify-between">
              <div class="flex flex-col gap-4">
                <div>
                  <h4 class="text-sm font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-1">Desafio</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Grandes custos (estimados em R$ 20.000/mês) para contratar empresas intermediadoras para implantar o prontuário eletrônico na rede municipal.</p>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-primary-600 dark:text-primary-400 uppercase tracking-widest mb-1">Solução</h4>
                  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Implantação e customização da infraestrutura do e-SUS usando exclusivamente servidores e equipe própria de servidores municipais.</p>
                </div>
              </div>
              <div class="mt-6 pt-6 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                <span class="text-xs text-slate-600 dark:text-slate-500 uppercase tracking-wider font-bold">Impacto Contínuo</span>
                <span class="text-lg font-black text-slate-900 dark:text-white">R$ 20.000 / mês economizados</span>
              </div>
            </div>
          </GlassCard>
        </div>
      </div>
    </section>

    <!-- TIMELINE SECTION -->
    <section id="timeline" class="py-24 border-t border-slate-200 dark:border-slate-900 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Trajetória Profissional</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Milestones marcantes e conquistas construídas ao longo dos últimos anos de carreira.</p>
        </div>

