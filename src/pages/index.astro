---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import ContactForm from '../components/ui/ContactForm.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { buildPersonSchema } from '../lib/seo';
import { site } from '../content/site';

// Import real profile photos and case assets uploaded by the user
import profilePhoto from '../assets/ISMAEL PERFIL_COMPLETA.png';
import codingPhoto from '../assets/ismael-codificando.png';
import notebookPhoto from '../assets/ismael-notebook.png';
import futurePhoto from '../assets/ismael-observando-futuro.png';

const personSchema = buildPersonSchema();
---

<BaseLayout 
  title="Ismael Soilet | Product Owner, Developer & Gestor Público" 
  description="Portfolio profissional de Ismael Hosni Soilet de Lima. Especialista em Transformação Digital, Ciência de Dados, Gestão Estratégica e Criador do FiscalizaPlus."
>
  {personSchema && <JsonLd schema={personSchema} />}

  <div class="home-wrapper">
    <!-- HERO SECTION -->
    <section id="hero" class="hero-section flex items-center justify-center relative overflow-hidden min-h-[90vh]">
      <div class="absolute inset-0 -z-10 bg-slate-50 dark:bg-navy"></div>

      <div class="max-w-5xl mx-auto px-6 py-20 text-center flex flex-col items-center gap-8 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-cyber-500/30 bg-cyber-500/5 text-cyber-600 dark:text-cyber-400 text-xs font-semibold tracking-wider uppercase animate-fade-in">
          <svg class="w-3.5 h-3.5 animate-spin-slow" aria-hidden="true"><use href="/icons/sprite.svg#icon-sparkle" /></svg>
          Tecnologia & Administração
        </div>

        <h1 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-black tracking-tight leading-none uppercase text-slate-900 dark:text-white">
          Ismael Hosni Soilet de Lima
        </h1>

        <div class="ticker-wrapper h-12 overflow-hidden flex items-start justify-center text-xl md:text-2xl font-bold text-slate-700 dark:text-slate-300">
          <div class="ticker-track">
            <div class="ticker-item py-1">Servidor público</div>
            <div class="ticker-item py-1">Gestor de Projetos</div>
            <div class="ticker-item py-1">Desenvolvedor</div>
            <div class="ticker-item py-1">Empreendedor</div>
            <div class="ticker-item py-1">Servidor público</div>
          </div>
        </div>

        <p class="max-w-2xl text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed font-medium">
          Transformo regras de negócio complexas em soluções digitais de alto impacto. Unindo Tecnologia da Informação, Ciência de Dados, Gestão de Projetos e Gestão Estratégica para gerar economia milionária e desburocratização.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-4">
          <a href="#timeline" class="px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-bold rounded-xl shadow-lg transition duration-300 active:scale-95 text-center">
            Conhecer Trajetória
          </a>
          <a href="#contact" class="px-8 py-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 text-slate-700 dark:text-slate-200 font-bold rounded-xl transition duration-300 active:scale-95 text-center backdrop-blur-sm">
            Entrar em Contato
          </a>
        </div>

        <div class="scroll-indicator absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce cursor-pointer">
          <a href="#about" aria-label="Rolar para baixo">
            <svg class="w-6 h-6 text-slate-400 dark:text-slate-500 hover:text-cyber-600 dark:hover:text-cyber-400 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT BENTO GRID -->
    <section id="about" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-slate-50 dark:bg-slate-950/20 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Perfil Multidisciplinar</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Uma combinação estratégica de competências para resolver problemas complexos em grande escala.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Photo Card -->
          <div class="md:row-span-2 rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800/80 bg-slate-100 dark:bg-slate-900/40 backdrop-blur-md relative group">
            <Image src={profilePhoto} alt="Ismael Soilet" class="w-full h-full object-cover grayscale group-hover:grayscale-0 about-photo transition-[filter] duration-[2000ms] ease-in-out" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent p-6 flex flex-col justify-end"></div>
          </div>

          <!-- Bio Narrative Card -->
          <GlassCard class="md:col-span-2 rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <div>
              <span class="text-xs font-semibold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest block mb-4">Minha História</span>
              <h3 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">Como Gestor, Desenvolvedor, Líder e Empreendedor</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                Minha história é abrangente e repleta de desafios superados. Atuo integrando liderança de equipes, desenvolvimento de software, gestão de projetos e empreendedorismo para transformar governos e organizações. Lidero iniciativas de digitalização (paperless), modernização e desenvolvimento de softwares, aliando visão estratégica à capacidade de execução para desatar nós burocráticos.
              </p>
            </div>
            <div class="flex flex-wrap gap-3">
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Liderança de TI</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Desenvolvimento de Software</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Ciência de Dados</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Gestão de Projetos</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Empreendedorismo</span>
              <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300">Governança Pública</span>
            </div>
          </GlassCard>

          <!-- Quote Card -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <svg class="w-8 h-8 text-cyber-500/40 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-4.765 2.627-5.023 5.424.301-.15.688-.225 1.054-.225 1.761 0 3.208 1.447 3.208 3.208.001 1.761-1.447 3.208-3.208 3.208-1.76 0-3.023-1.189-3.023-3.208v-1.558c0-3.328 1.956-6.113 4.542-7.505l-.995-2.151C14.07 4.908 9.571 8.8 9.571 14.156v6.844h4.446zm-10 0v-7.391c0-5.704 3.73-9.57 8.983-10.609l.994 2.151c-2.432.917-4.764 2.627-5.023 5.424.302-.15.688-.225 1.054-.225 1.761 0 3.208 1.447 3.208 3.208.001 1.761-1.447 3.208-3.208 3.208-1.76 0-3.024-1.189-3.024-3.208v-1.558c0-3.328 1.956-6.113 4.542-7.505l-.995-2.151C4.07 4.908.571 8.8.571 14.156v6.844h4.446z"/></svg>
            <p class="text-slate-700 dark:text-slate-300 font-medium italic text-lg leading-relaxed mb-4">
              "Construo ecossistemas ágeis que modernizam processos, desburocratizam serviços, aumentam a performance da equipe e geram economia milionária."
            </p>
            <span class="text-xs text-slate-600 dark:text-slate-500 font-bold uppercase tracking-wider">— Filosofia de Trabalho</span>
          </GlassCard>

          <!-- Experience Card -->
          <GlassCard class="rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8 flex flex-col justify-between">
            <span class="text-xs font-semibold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest block mb-4">Tempo</span>
            <div class="flex items-baseline gap-2">
              <span class="text-6xl font-black text-primary-600 dark:text-primary-400">15+</span>
              <span class="text-lg font-bold text-slate-700 dark:text-slate-300">Anos</span>
            </div>
            <p class="text-slate-600 dark:text-slate-400 mt-2 text-sm leading-relaxed">
              De experiência atuando como elo estratégico entre equipes técnicas e regras de negócio complexas de administração pública e empreendimentos privados. Capacitação contínua em administração, gestão de projetos e tecnologia, atuando na vanguarda da Inteligência Artificial para transformar e otimizar processos.
            </p>
          </GlassCard>
        </div>
      </div>
    </section>

    <!-- ATUAÇÃO POR EIXOS (TABS) -->
    <section id="atuacao" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-white dark:bg-slate-900/10 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Áreas de Atuação</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4 max-w-xl mx-auto">Resultados, cases e marcos organizados por eixo de competência.</p>
        </div>

        <div data-tabs-container class="w-full">
          <!-- Tab Buttons (grid 2x2 mobile, 4 cols desktop) -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 p-1.5 rounded-2xl bg-slate-100 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800/80" role="tablist" aria-label="Eixos de atuação">
            <button role="tab" id="atuacao-tab-desenvolvimento" aria-selected="true" aria-controls="atuacao-panel-desenvolvimento" tabindex="0" data-tab-btn="desenvolvimento" class="tab-btn-active px-4 py-3 text-xs sm:text-sm font-semibold rounded-xl transition-all select-none focus:outline-none focus:ring-2 focus:ring-cyber-500/50 text-center">
              Software
            </button>
            <button role="tab" id="atuacao-tab-gestao" aria-selected="false" aria-controls="atuacao-panel-gestao" tabindex="-1" data-tab-btn="gestao" class="tab-btn px-4 py-3 text-xs sm:text-sm font-semibold rounded-xl transition-all select-none focus:outline-none focus:ring-2 focus:ring-cyber-500/50 text-center">
              Projetos
            </button>
            <button role="tab" id="atuacao-tab-administracao" aria-selected="false" aria-controls="atuacao-panel-administracao" tabindex="-1" data-tab-btn="administracao" class="tab-btn px-4 py-3 text-xs sm:text-sm font-semibold rounded-xl transition-all select-none focus:outline-none focus:ring-2 focus:ring-cyber-500/50 text-center">
              Administração
            </button>
            <button role="tab" id="atuacao-tab-empreendedorismo" aria-selected="false" aria-controls="atuacao-panel-empreendedorismo" tabindex="-1" data-tab-btn="empreendedorismo" class="tab-btn px-4 py-3 text-xs sm:text-sm font-semibold rounded-xl transition-all select-none focus:outline-none focus:ring-2 focus:ring-cyber-500/50 text-center">
              Empreender
            </button>
          </div>

          <div class="relative w-full mt-8">

            <!-- === PAINEL 1: Desenvolvimento de Software === -->
            <div role="tabpanel" id="atuacao-panel-desenvolvimento" aria-labelledby="atuacao-tab-desenvolvimento" tabindex="0" data-tab-panel="desenvolvimento" class="block opacity-100 translate-y-0 focus:outline-none focus:ring-2 focus:ring-cyber-500/50 rounded-xl transition-all duration-300">

              <!-- Photo Cover -->
              <div class="relative aspect-[4/3] sm:aspect-[5/3] rounded-2xl overflow-hidden mb-8 group">
                <Image src={codingPhoto} alt="Desenvolvimento de Software" class="w-full h-full object-cover object-center group-hover:scale-102 transition duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/95 via-slate-950/40 to-transparent flex flex-col justify-end p-5 sm:p-6 md:px-10 md:pb-8 pb-6">
                  <span class="px-3.5 py-2 rounded-lg bg-cyber-500/20 text-cyber-300 text-xs sm:text-sm font-bold uppercase tracking-wider w-fit mb-2 sm:mb-3 backdrop-blur-sm">Desenvolvimento de Software</span>
                  <p class="text-white/95 text-sm sm:text-base md:text-lg font-medium max-w-md leading-snug">Ecossistema SuitPlus + Digital Landing. Criação de sistemas completos e aplicações de alta performance.</p>
                </div>
              </div>

              <!-- ROI Stats -->
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
                <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-6 flex flex-col justify-between relative group hover:border-cyber-500/30">
                  <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-1">FiscalizaPlus</div>
                  <div class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="25000" data-format="currency" data-suffix="/mês">R$ 0</div>
                  <p class="text-sm text-slate-500 mt-2">Economia mensal eliminando licenças de terceiros</p>
                </GlassCard>
                <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-6 flex flex-col justify-between relative group hover:border-cyber-500/30">
                  <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-1">Ecossistema SuitPlus</div>
                  <div class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-format="static">6+</div>
                  <p class="text-sm text-slate-500 mt-2">Soluções integradas de gestão pública e privada</p>
                </GlassCard>
                <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-6 flex flex-col justify-between relative group hover:border-cyber-500/30">
                  <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-1">Digital Landing</div>
                  <div class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-format="static">Sites & APPs</div>
                  <p class="text-sm text-slate-500 mt-2">Landing pages, hubs institucionais e aplicações web</p>
                </GlassCard>
              </div>

              <!-- Cases -->
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Cases do Eixo</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
                <!-- Case: FiscalizaPlus -->
                <GlassCard class="rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 transition-colors">
                  <div class="px-5 py-3 border-b border-slate-200/60 dark:border-slate-800/60 flex items-center justify-between bg-slate-50 dark:bg-slate-900/40">
                    <span class="text-base font-bold text-slate-900 dark:text-white">FiscalizaPlus</span>
                    <span class="px-2.5 py-0.5 rounded bg-cyber-500/20 text-cyber-600 dark:text-cyber-400 text-xs font-bold uppercase tracking-wider">Inovação em Produto</span>
                  </div>
                  <div class="p-6 flex-grow flex flex-col justify-between">
                    <div class="flex flex-col gap-3">
                      <div>
                        <h4 class="text-xs font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-0.5">Desafio</h4>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">R$ 25.000/mês em licenças de softwares terceirizados ineficientes na fiscalização tributária municipal.</p>
                      </div>
                      <div>
                        <h4 class="text-xs font-bold text-primary-700 dark:text-primary-400 uppercase tracking-widest mb-0.5">Solução</h4>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Software próprio customizado com geointeligência, offline-first e automação documental.</p>
                      </div>
                    </div>
                    <div class="mt-4 pt-4 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                      <span class="text-xs text-slate-500 uppercase tracking-wider font-bold">Impacto</span>
                      <span class="text-base font-black text-slate-900 dark:text-white">R$ 25.000 / mês</span>
                    </div>
                  </div>
                </GlassCard>

                <!-- Case: Digital Landing -->
                <GlassCard class="rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col justify-between hover:border-cyber-500/20 transition-colors">
                  <div class="px-5 py-3 border-b border-slate-200/60 dark:border-slate-800/60 flex items-center justify-between bg-slate-50 dark:bg-slate-900/40">
                    <span class="text-base font-bold text-slate-900 dark:text-white">Digital Landing</span>
                    <span class="px-2.5 py-0.5 rounded bg-primary-500/20 text-primary-700 dark:text-primary-400 text-xs font-bold uppercase tracking-wider">Serviços Web</span>
                  </div>
                  <div class="p-6 flex-grow flex flex-col justify-between">
                    <div class="flex flex-col gap-3">
                      <div>
                        <h4 class="text-xs font-bold text-cyber-600 dark:text-cyber-400 uppercase tracking-widest mb-0.5">Desafio</h4>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Empresas e instituições precisam de presença digital profissional com performance, SEO e AIO.</p>
                      </div>
                      <div>
                        <h4 class="text-xs font-bold text-primary-700 dark:text-primary-400 uppercase tracking-widest mb-0.5">Solução</h4>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Desenvolvimento de landing pages, hubs institucionais e otimização para buscadores e IAs.</p>
                      </div>
                    </div>
                    <div class="mt-4 pt-4 border-t border-slate-200/60 dark:border-slate-800/60 flex justify-between items-center">
                      <span class="text-xs text-slate-500 uppercase tracking-wider font-bold">Entregas</span>
                      <span class="text-base font-black text-slate-900 dark:text-white">Performance Máxima</span>
                    </div>
                  </div>
                </GlassCard>
              </div>

              <!-- Marcos do Eixo -->
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Marcos</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <GlassCard class="rounded-xl border border-slate-200 dark:border-slate-800 p-5 flex items-start gap-4 hover:border-cyber-500/20">
                  <span class="shrink-0 w-10 h-10 rounded-full bg-cyber-500/10 text-cyber-600 dark:text-cyber-400 flex items-center justify-center font-black text-sm">2023</span>
                  <div>
                    <h4 class="font-bold text-slate-900 dark:text-white text-base">Início do Ecossistema SuitPlus</h4>
                    <p class="text-sm text-slate-500">Arquitetura e desenvolvimento do framework que originou o conjunto de soluções integradas.</p>
                  </div>
                </GlassCard>
                <GlassCard class="rounded-xl border border-slate-200 dark:border-slate-800 p-5 flex items-start gap-4 hover:border-cyber-500/20">
                  <span class="shrink-0 w-10 h-10 rounded-full bg-primary-500/10 text-primary-700 dark:text-primary-400 flex items-center justify-center font-black text-sm">2025</span>
                  <div>
                    <h4 class="font-bold text-slate-900 dark:text-white text-base">Lançamento FiscalizaPlus</h4>
                    <p class="text-sm text-slate-500">Produto próprio de fiscalização municipal substituindo sistemas terceirizados.</p>
                  </div>
                </GlassCard>
              </div>
            </div>

            <!-- === PAINEL 2: Gestão de Projetos === -->
            <div role="tabpanel" id="atuacao-panel-gestao" aria-labelledby="atuacao-tab-gestao" tabindex="0" data-tab-panel="gestao" class="hidden opacity-0 translate-y-2 focus:outline-none focus:ring-2 focus:ring-cyber-500/50 rounded-xl transition-all duration-300">

              <!-- Photo Cover -->
              <div class="relative aspect-[4/3] sm:aspect-[5/3] rounded-2xl overflow-hidden mb-8 group">
                <Image src={notebookPhoto} alt="Gestão de Projetos" class="w-full h-full object-cover object-center group-hover:scale-102 transition duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/95 via-slate-950/40 to-transparent flex flex-col justify-end p-5 sm:p-6 md:px-10 md:pb-8 pb-6">
                  <span class="px-3.5 py-2 rounded-lg bg-primary-500/20 text-primary-300 text-xs sm:text-sm font-bold uppercase tracking-wider w-fit mb-2 sm:mb-3 backdrop-blur-sm">Gestão de Projetos</span>
                  <p class="text-white/95 text-sm sm:text-base md:text-lg font-medium max-w-md leading-snug">Transformação digital em escala municipal. Implantação e coordenação de digitalização em larga escala.</p>
                </div>
              </div>

              <!-- ROI Stats -->
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
                <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-6 flex flex-col justify-between relative group hover:border-cyber-500/30">
                  <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-1">Paperless</div>
                  <div class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white group-hover:text-cyber-600 dark:group-hover:text-cyber-400 transition" data-target="350000" data-format="number" data-suffix="+">0</div>
                  <p class="text-sm text-slate-500 mt-2">Processos físicos migrados para o formato digital</p>
                </GlassCard>
                <GlassCard class="metric-card rounded-2xl border border-slate-200 dark:border-slate-800/80 p-6 flex flex-col justify-between relative group hover:border-cyber-500/30">
                  <div class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-1">IPTU & ISS Digitais</div>
