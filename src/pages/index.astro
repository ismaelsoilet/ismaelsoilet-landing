    <section id="contact" class="py-24 border-t border-slate-200 dark:border-slate-900 bg-slate-50 dark:bg-slate-900/10 reveal">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white">Iniciar um Projeto</h2>
          <p class="text-slate-600 dark:text-slate-400 mt-4">Entre em contato para consultorias de desburocratização, engenharia de software ou parcerias estratégicas.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          <!-- Direct Channels -->
          <div class="md:col-span-1 flex flex-col gap-4">
            <a href={`mailto:${site.contact.email}`} class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30 p-6 flex flex-col gap-2 hover:border-cyber-500/20 transition">
              <svg class="w-6 h-6 text-cyber-600 dark:text-cyber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <span class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">E-mail</span>
              <span class="text-sm font-bold text-slate-900 dark:text-white break-all">{site.contact.email}</span>
            </a>

            <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30 p-6 flex flex-col gap-2 hover:border-primary-500/20 transition">
              <svg class="w-6 h-6 text-emerald-500 dark:text-emerald-400"><use href="/icons/sprite.svg#icon-whatsapp-logo" /></svg>
              <span class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wider">WhatsApp</span>
              <span class="text-sm font-bold text-slate-900 dark:text-white">{site.contact.phone}</span>
            </a>
          </div>

          <!-- Contact Form with Honeypot -->
          <GlassCard class="md:col-span-2 rounded-3xl border border-slate-200 dark:border-slate-800/80 p-8">
            <ContactForm />
          </GlassCard>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<!-- CUSTOM SCOPED STYLE FOR PREMIUM AESTHETIC (dark-default, light-aware) -->
<style is:global>
  .animate-spin-slow {
    animation: spin 8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Animated Role Ticker */
  .ticker-wrapper {
    mask-image: linear-gradient(to bottom, transparent, white 20%, white 80%, transparent);
    overflow: hidden;
  }

  .ticker-track {
    animation: ticker 12s cubic-bezier(0.76, 0, 0.24, 1) infinite;
  }

  @keyframes ticker {
    0%, 18% { transform: translateY(0); }
    22%, 40% { transform: translateY(-20%); }
    44%, 62% { transform: translateY(-40%); }
    66%, 84% { transform: translateY(-60%); }
    88%, 100% { transform: translateY(-80%); }
  }

  .animate-pulse-slow {
    animation: pulseSlow 6s ease-in-out infinite;
  }

  @keyframes pulseSlow {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  /* About photo: colored when section is in view */
  .about-photo {
    filter: grayscale(100%);
  }
  .about-photo.colored,
  .group:hover .about-photo {
    filter: grayscale(0%);
  }

  /* Scroll-driven Reveal Animations */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .reveal {
        animation: revealUp 1s ease-out both;
        animation-timeline: view();
        animation-range: entry 5% entry 30%;
      }
    }
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Tab Pill Toggle — LinkedIn blue solid */
  .tab-btn {
    color: rgb(100 116 139); /* slate-500 */
    background: transparent;
  }
  html.dark .tab-btn {
    color: rgb(148 163 184); /* slate-400 */
  }
  .tab-btn:hover {
    color: #0a66c2; /* LinkedIn primary */
    background: rgb(241 245 249); /* slate-100 */
  }
  html.dark .tab-btn:hover {
    color: #4d8ec9; /* LinkedIn primary lighter */
    background: rgb(30 41 59 / 0.4); /* slate-800/40 */
  }
  .tab-btn-active {
    color: rgb(255 255 255);
    background: #0a66c2; /* LinkedIn primary */
    box-shadow: 0 4px 14px 0 rgb(10 102 194 / 0.25);
  }
  .tab-btn-active:hover {
    color: rgb(255 255 255);
    background: #004182; /* LinkedIn primary dark */
  }

  /* Accessibility: prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-delay: 0s !important;
      animation-duration: 0s !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0s !important;
      scroll-behavior: auto !important;
    }
    .ticker-track {
      animation: none !important;
    }
  }
</style>

<script>
  // Tab Switching
  function initTabs() {
    const containers = document.querySelectorAll('[data-tabs-container]');
    containers.forEach((container : any) => {
      const buttons : any = container.querySelectorAll('[data-tab-btn]');
      const panels : any = container.querySelectorAll('[data-tab-panel]');

      buttons.forEach((btn : any, idx : number) => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-tab-btn');

          buttons.forEach((b : any) => {
            const isTarget = b.getAttribute('data-tab-btn') === targetId;
            b.setAttribute('aria-selected', isTarget ? 'true' : 'false');
            b.setAttribute('tabindex', isTarget ? '0' : '-1');
            if (isTarget) {
              b.classList.remove('tab-btn');
              b.classList.add('tab-btn-active');
            } else {
              b.classList.remove('tab-btn-active');
              b.classList.add('tab-btn');
            }
          });

          panels.forEach((panel : any) => {
            const isTarget = panel.getAttribute('data-tab-panel') === targetId;
            if (isTarget) {
              panel.classList.remove('hidden');
              setTimeout(() => {
                panel.classList.remove('opacity-0', 'translate-y-2');
                panel.classList.add('opacity-100', 'translate-y-0');
              }, 50);
              animateCountersIn(panel);
            } else {
              panel.classList.add('hidden', 'opacity-0', 'translate-y-2');
              panel.classList.remove('opacity-100', 'translate-y-0');
            }
          });
        });

        btn.addEventListener('keydown', (e : any) => {
          let targetIdx : number | null = null;
          if (e.key === 'ArrowRight') targetIdx = (idx + 1) % buttons.length;
          if (e.key === 'ArrowLeft') targetIdx = (idx - 1 + buttons.length) % buttons.length;
          if (targetIdx !== null) {
            (buttons[targetIdx] as HTMLElement).focus();
            (buttons[targetIdx] as HTMLElement).click();
          }
        });
      });
    });
  }

  // Generic Counter Animation
  function animateCountersIn(container : any) {
    const cards : any = container.querySelectorAll('.metric-card');
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const options = { threshold: 0.2, rootMargin: '0px' };

    const observer = new IntersectionObserver((entries : any, observer : any) => {
      entries.forEach((entry : any) => {
        if (entry.isIntersecting) {
          const numberEl : any = entry.target.querySelector('[data-target]');
          if (numberEl) {
            const target = parseInt(numberEl.getAttribute('data-target') || '0', 10);
            const format = numberEl.getAttribute('data-format') || '';
            const suffix = numberEl.getAttribute('data-suffix') || '';

            if (format === 'static') {
              observer.unobserve(entry.target);
              return;
            }

            const formatFinal = (val : number) => {
              if (format === 'currency') return 'R$ ' + val.toLocaleString('pt-BR') + suffix;
              if (format === 'number') return val.toLocaleString('pt-BR') + suffix;
              if (format === 'percent') return val + suffix;
              return val.toLocaleString('pt-BR') + suffix;
            };

            if (prefersReducedMotion) {
              numberEl.textContent = formatFinal(target);
            } else {
              let count = 0;
              const duration = 1500;
              const stepTime = 16;
              const steps = duration / stepTime;
              const increment = target / steps;

              const timer = setInterval(() => {
                count += increment;
                if (count >= target) {
                  clearInterval(timer);
                  numberEl.textContent = formatFinal(target);
                } else {
                  if (format === 'currency') {
                    numberEl.textContent = 'R$ ' + Math.floor(count).toLocaleString('pt-BR');
                  } else if (format === 'number') {
                    numberEl.textContent = Math.floor(count).toLocaleString('pt-BR') + '+';
                  } else if (format === 'percent') {
                    numberEl.textContent = Math.floor(count) + '%';
                  } else {
                    numberEl.textContent = Math.floor(count).toLocaleString('pt-BR');
                  }
                }
              }, stepTime);
            }
          }
          observer.unobserve(entry.target);
        }
      });
    }, options);

    cards.forEach((card : any) => observer.observe(card));
  }

  function animateCounters() {
    animateCountersIn(document);
  }

  // About photo: color when section enters viewport
  function initAboutPhotoObserver() {
    const about = document.getElementById('about');
    const photo = document.querySelector('.about-photo');
    if (!about || !photo) return;
    const observer = new IntersectionObserver((entries : any) => {
      entries.forEach((entry : any) => {
        if (entry.isIntersecting) {
          photo.classList.add('colored');
        } else {
          photo.classList.remove('colored');
        }
      });
    }, { threshold: 0.25 });
    observer.observe(about);
  }

  // Handle Form Submission via Webhook
  function handleFormSubmission() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const feedback = document.getElementById('form-feedback');
    if (!form || !feedback) return;

    form.addEventListener('submit', async (e : any) => {
      e.preventDefault();

      const honeypot = document.getElementById('honeypot_field') as HTMLInputElement | null;
      if (honeypot && honeypot.value) {
        feedback.textContent = 'Mensagem enviada com sucesso (filtro anti-spam ativo).';
        feedback.className = 'mt-4 text-sm text-center font-bold text-primary-600 dark:text-primary-400 block';
        form.reset();
        return;
      }

      feedback.textContent = 'Enviando...';
      feedback.className = 'mt-4 text-sm text-center font-bold text-cyber-600 dark:text-cyber-400 block';

      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(data)
        });
        if (response.ok) {
          feedback.textContent = 'Mensagem enviada com sucesso! Em breve entrarei em contato.';
          feedback.className = 'mt-4 text-sm text-center font-bold text-primary-600 dark:text-primary-400 block';
          form.reset();
        } else {
          throw new Error('Falha no envio.');
        }
      } catch (err) {
        feedback.textContent = 'Erro ao enviar mensagem. Por favor, utilize o WhatsApp ou e-mail.';
        feedback.className = 'mt-4 text-sm text-center font-bold text-red-600 dark:text-red-400 block';
      }
    });
  }

  // Bind JS on Astro transitions and initial load
  document.addEventListener('astro:page-load', () => {
    initTabs();
    animateCounters();
    initAboutPhotoObserver();
    handleFormSubmission();
  });
</script>
