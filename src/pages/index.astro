---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { buildFaqSchema } from '../lib/seo';

const faqsCollection = await getCollection('faqs');
const faqData = faqsCollection.map(faq => faq.data);
const faqSchema = buildFaqSchema(faqData);
---

<BaseLayout title="Template Definitivo — Guia Interativo de CRO, SEO e Alta Performance" description="O template definitivo de Landing Page em HTML5 e Tailwind CSS.">
  <JsonLd schema={faqSchema} />
  <!-- Estilos Legados e customizados da Home -->
  <style>
    /* 
================================================================================
   CSS DESIGN SYSTEM DEFINITIVO — TEMPLATE LANDING (VANILLA CSS)
   Objetivo: Fornecer um framework visual ultra-premium, de alta velocidade,
   100% responsivo, com suporte a temas (claro/escuro) e micro-animações.
   
   COMO USAR ESTE TEMPLATE:
   - Modifique as variáveis no bloco :root para alterar a paleta de cores global.
   - Use as classes utilitárias para layouts rápidos (ex: .grid-2, .flex-between).
   - Mantenha a nomenclatura semântica para fins de acessibilidade e SEO.
================================================================================
*/



/* 2. VARIÁVEIS DO SISTEMA DE DESIGN (CSS Variables)
   Permite alterar a identidade visual de todo o site modificando apenas estes valores.
   Temos duas versões: Light Mode (Padrão) e Dark Mode (:global(.dark)).
*/
:root {
    /* Cores de Marca (Claras) */
    --primary: var(--color-indigo-500);         /* Indigo Intenso */
    --primary-hover: var(--color-indigo-600);
    --primary-rgb: 99, 102, 241;
    --secondary: var(--color-pink-500);       /* Rosa Vibrante */
    --secondary-hover: var(--color-pink-600);
    --accent: var(--color-teal-500);          /* Teal Moderno */
    
    /* Cores de Fundo e Texto (Light Mode) */
    --bg-main: var(--color-slate-50);         /* Fundo sutilmente cinza */
    --bg-card: var(--color-white);         /* Fundo de cartões */
    --bg-glass: rgba(255, 255, 255, 0.7);
    --border-color: var(--color-slate-200);    /* Bordas suaves */
    --border-glass: rgba(255, 255, 255, 0.4);
    
    --text-title: var(--color-slate-900);      /* Slate 900 */
    --text-body: var(--color-slate-700);       /* Slate 700 */
    --text-muted: var(--color-slate-500);      /* Slate 500 */
    
    /* Sombras e Efeitos */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.08);
    --shadow-premium: 0 20px 25px -5px rgba(99, 102, 241, 0.05), 0 10px 10px -5px rgba(99, 102, 241, 0.02);
    
    /* Configurações Gerais */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-full: 9999px;
    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-normal: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    
    --font-title: var(--font-sans);
    --font-body: var(--font-sans);
    --container-width: 1280px;
}

/* Override para Tema Escuro (Dark Mode)
   Ativado adicionando a classe '.dark' na tag <html> ou <body>
*/
:global(.dark) {
    --bg-main: var(--color-slate-950);         /* Deep Space Blue */
    --bg-card: var(--color-slate-900);         /* Slate 900 */
    --bg-glass: rgba(15, 23, 42, 0.7);
    --border-color: var(--color-slate-800);    /* Slate 800 */
    --border-glass: rgba(255, 255, 255, 0.08);
    
    --text-title: var(--color-slate-50);      /* Slate 50 */
    --text-body: var(--color-slate-400);       /* Slate 400 */
    --text-muted: var(--color-slate-500);      /* Slate 500 */
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -2px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.4);
    --shadow-premium: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
}

.home-wrapper {
    background-color: var(--bg-main);
    color: var(--text-body);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
    width: 100%;
    position: relative;
    transition: background-color var(--transition-normal), color var(--transition-normal);
}

/* 4. TIPOGRAFIA SEMÂNTICA
   Estilos focados em hierarquia de cabeçalhos de alta conversão.
*/
h1, h2, h3, h4, h5, h6 {
    color: var(--text-title);
    font-family: var(--font-title);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
}

h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; }
h2 { font-size: clamp(2rem, 4vw, 2.75rem); }
h3 { font-size: clamp(1.5rem, 3vw, 1.875rem); }
h4 { font-size: clamp(1.25rem, 2vw, 1.5rem); }

p {
    margin-bottom: 1.25rem;
}

a {
    color: var(--primary);
    text-decoration: none;
    transition: color var(--transition-fast);
}
a:hover {
    color: var(--primary-hover);
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}

/* 5. CLASSES DE LAYOUT & CONTAINER */
.container {
    width: 100%;
    max-width: var(--container-width);
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
}

.section {
    padding-top: clamp(4rem, 10vw, 8rem);
    padding-bottom: clamp(4rem, 10vw, 8rem);
    position: relative;
}

/* Grids Responsivos Universais */
.grid {
    display: grid;
    gap: 2rem;
}
.grid-2 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
.grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
.grid-4 { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }

/* Bento Grid assimétrico moderno */
.bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
}
.bento-item {
    grid-column: span 12;
}
@media (min-width: 768px) {
    .bento-col-4 { grid-column: span 4; }
    .bento-col-8 { grid-column: span 8; }
    .bento-col-6 { grid-column: span 6; }
}

/* Flexbox Helpers */
.flex { display: flex; }
.flex-v { flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.gap-1 { gap: 0.5rem; }
.gap-2 { gap: 1rem; }
.gap-3 { gap: 1.5rem; }
.gap-4 { gap: 2rem; }

/* 6. BOTÕES ULTRA-PREMIUM (CRO E ENGAJAMENTO) */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 1rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
}

.btn-primary {
    background-color: var(--primary);
    color: #ffffff;
    box-shadow: 0 4px 14px 0 rgba(99, 102, 241, 0.4);
}
.btn-primary:hover {
    background-color: var(--primary-hover);
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px 0 rgba(99, 102, 241, 0.5);
}

.btn-secondary {
    background-color: transparent;
    border-color: var(--border-color);
    color: var(--text-title);
}
.btn-secondary:hover {
    background-color: var(--border-color);
    transform: translateY(-2px);
}

.btn-glow {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: #ffffff;
    box-shadow: 0 4px 20px 0 rgba(236, 72, 153, 0.3);
}
.btn-glow:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px 0 rgba(236, 72, 153, 0.5);
}

/* 7. GLASSMORPHISM & CARTÕES PREMIUM */
.glass-card {
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-premium);
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
}

.glass-card:hover {
    border-color: rgba(99, 102, 241, 0.2);
    box-shadow: 0 20px 40px -15px rgba(99, 102, 241, 0.12);
}

/* Spotlight Effect: Iluminação dinâmica controlada via JS mousemove */
.glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(800px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), rgba(99, 102, 241, 0.06), transparent 40%);
    pointer-events: none;
    z-index: 0;
}

/* 8. ANIMAÇÕES & ELEMENTOS DE SUPORTE */
.blob {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(236, 72, 153, 0.05) 70%, transparent 100%);
    filter: blur(50px);
    z-index: -1;
    pointer-events: none;
}

.blob-1 {
    top: 10%;
    right: -10%;
    animation: float-blob 20s infinite alternate;
}

.blob-2 {
    bottom: 20%;
    left: -10%;
    animation: float-blob 25s infinite alternate-reverse;
}

@keyframes float-blob {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -60px) scale(1.1); }
    100% { transform: translate(-20px, 20px) scale(0.95); }
}



/* 10. COMPONENTES: TRUST BAR INFINITO
   Carrossel infinito de logos com renderização acelerada por GPU.
*/
.logo-carousel-container {
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(to right, transparent, #000 10%, #000 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, #000 10%, #000 90%, transparent);
}

.logo-carousel {
    display: flex;
    width: max-content;
    gap: 4rem;
    animation: scroll-carousel 30s linear infinite;
}

.logo-carousel img {
    height: 28px;
    filter: grayscale(1) opacity(0.5);
    transition: filter var(--transition-fast);
}

.logo-carousel img:hover {
    filter: grayscale(0) opacity(1);
}

@keyframes scroll-carousel {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* 11. COMPONENTES: CAROUSEL / ABAS DE SOLUÇÕES (TABS - SUITPLUS STYLE) */
#solutions-carousel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: stretch;
}

.solutions-tabs-container {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    width: 100%;
}
.solutions-tabs-container::-webkit-scrollbar {
    display: none;
}
.solutions-tabs-container [role="tablist"] {
    display: flex;
    gap: 0.5rem;
}

.solutions-tab {
    cursor: pointer;
    white-space: nowrap;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition: all var(--transition-fast);
    font-weight: 600;
    color: var(--text-muted);
    background: transparent;
    flex-shrink: 0;
    scroll-snap-align: center;
}

.solutions-tab:hover {
    color: var(--text-title);
    background-color: rgba(99, 102, 241, 0.05);
}

.solutions-tab.active {
    background-color: rgba(99, 102, 241, 0.08);
    border-bottom: 3px solid var(--system-color, var(--primary));
    color: var(--text-title) !important;
    border-radius: var(--radius-sm);
}

.solutions-card-container {
    height: 340px;
    position: relative;
    width: 100%;
}

.solutions-panel.hidden {
    display: none !important;
}

.solutions-panel:not(.hidden) {
    animation: solutionFadeIn var(--transition-normal) cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes solutionFadeIn {
    from {
        opacity: 0;
        transform: scale(0.98);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

/* Layout Desktop: abas verticais à esquerda, cartão visual 3D ao centro, descrições à direita */
@media (min-width: 1024px) {
    #solutions-carousel {
        display: grid;
        grid-template-columns: 260px 1.1fr 1fr;
        gap: 3rem;
        align-items: start;
    }

    .solutions-card-container {
        height: 450px;
    }

    .solutions-tabs-container {
        overflow-x: visible;
        scroll-snap-type: none;
        padding-bottom: 0;
    }

    .solutions-tabs-container [role="tablist"] {
        flex-direction: column;
        gap: 0.25rem;
    }

    .solutions-tab {
        border-bottom: none;
        border-left: 3px solid transparent;
        white-space: normal;
        scroll-snap-align: unset;
        border-radius: var(--radius-md);
        text-align: left;
    }

    .solutions-tab.active {
        border-left-color: var(--system-color, var(--primary));
        border-bottom-color: transparent;
        background-color: rgba(99, 102, 241, 0.08);
    }
}

@keyframes fade-in-scale {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: scale(1); }
}

/* 12. COMPONENTES: TABELAS DE PREÇO (PRICING TABLES) */
.pricing-card {
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
}
.pricing-card.featured {
    border: 2px solid var(--primary);
    transform: scale(1.03);
}
@media (max-width: 768px) {
    .pricing-card.featured {
        transform: scale(1);
    }
}
.pricing-features-list {
    list-style: none;
}
.pricing-features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
    font-size: 0.95rem;
}

/* 13. COMPONENTES: FAQ RETRÁTIL SEMÂNTICO (ACCORDION) */
.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.5rem 0;
}
.faq-question {
    width: 100%;
    background: transparent;
    border: none;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-title);
    padding: 0;
    gap: 1rem;
}
.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal), margin var(--transition-normal);
    color: var(--text-body);
    font-size: 1rem;
}
.faq-item.open .faq-answer {
    max-height: 300px;
    margin-top: 1rem;
}
.faq-icon {
    transition: transform var(--transition-fast);
    color: var(--primary);
}
.faq-item.open .faq-icon {
    transform: rotate(45deg);
}

/* 14. COMPONENTES: BLOG INDEX & ARTIGO */
.blog-card {
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
}
.blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.blog-tag {
    background: rgba(99, 102, 241, 0.08);
    color: var(--primary);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
}

/* Estilos Específicos da Página do Artigo */
.blog-toc {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
}

.blog-toc-link {
    display: block;
    padding: 0.35rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    transition: all var(--transition-fast);
}

.blog-toc-link.active, .blog-toc-link:hover {
    color: var(--primary);
    border-left-color: var(--primary);
}

.progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: transparent;
    z-index: 101;
}
.progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, var(--primary), var(--secondary));
}

/* 15. INTERACTION & SCROLL REVEAL (Micro-animações) */
.scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.animate-fade-in-up {
    opacity: 1;
    transform: translateY(0);
}

/* Transições SPA (View Transitions API Support)
   Estas animações dão o efeito "App nativo" sedoso e profissional.
*/
::view-transition-old(root) {
    animation: 250ms cubic-bezier(0.4, 0, 1, 1) both fade-out;
}
::view-transition-new(root) {
    animation: 300ms cubic-bezier(0, 0, 0.2, 1) both fade-in;
}

@keyframes fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
}
@keyframes fade-in {
    from { opacity: 0; transform: scale(0.99); }
    to { opacity: 1; transform: scale(1); }
}

/* 16. MODO PREFERES REDUCED MOTION (Acessibilidade) */
@media (prefers-reduced-motion: reduce) {
    html {
        scroll-behavior: auto;
    }
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
    }
    .scroll-reveal {
        opacity: 1 !important;
        transform: none !important;
    }
    .blob {
        animation: none !important;
    }
    /* Trust bar (logo carousel) is content, not decorative motion (WCAG 2.2.2) */
    .logo-carousel {
        animation: scroll-carousel 30s linear infinite !important;
    }
}

/* 17. COMPONENTES DE DEPOIMENTOS E AVALIAÇÕES DO GOOGLE (PROVA SOCIAL) */
.google-reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

.google-review-card {
    background: var(--bg-card);
    border: 2px solid var(--primary);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    position: relative;
    box-shadow: var(--shadow-premium);
}

.google-review-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.google-logo-text {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-title);
}

.google-score {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.google-score-number {
    font-size: 2rem;
    font-weight: 900;
    color: var(--text-title);
    line-height: 1;
}

.google-stars {
    color: #fbbf24;
    letter-spacing: 2px;
    font-size: 1.25rem;
}

.google-rating-text {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
}

.google-review-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
}

.google-review-link {
    background: var(--primary);
    color: #ffffff;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    transition: all var(--transition-fast);
}

.google-review-link:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
}

.google-write-review {
    background: var(--bg-main);
    color: var(--text-title);
    border: 1px solid var(--border-color);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: 0.9rem;
    transition: all var(--transition-fast);
}

.google-write-review:hover {
    background: var(--border-color);
    transform: translateY(-2px);
}

.testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    position: relative;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-normal);
}

.testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(99, 102, 241, 0.2);
}

.quote-icon {
    font-size: 3.5rem;
    color: rgba(99, 102, 241, 0.1);
    line-height: 1;
    font-family: serif;
    font-weight: bold;
    position: absolute;
    top: 1rem;
    right: 2rem;
}

.testimonial-card blockquote {
    color: var(--text-body);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-style: italic;
}

.testimonial-stars {
    color: #fbbf24;
    letter-spacing: 2px;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.testimonial-author {
    font-weight: 800;
    color: var(--text-title);
    font-size: 1rem;
}

.testimonial-location {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
}

@media (min-width: 768px) {
    .google-reviews-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .google-review-card {
        grid-column: span 2;
    }
}

@media (min-width: 1024px) {
    .google-reviews-grid {
