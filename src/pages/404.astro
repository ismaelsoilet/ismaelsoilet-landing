---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout 
  title="Página Não Encontrada (404)" 
  description="A página que você está procurando não existe ou foi movida." 
  noindex={true}
>
  <div class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="max-w-md w-full text-center flex flex-col gap-6 py-12">
      <div class="relative flex justify-center mb-2">
        <span class="text-8xl font-black bg-gradient-to-r from-cyber-400 to-primary-500 bg-clip-text text-transparent opacity-80 animate-pulse">404</span>
      </div>
      <div class="flex flex-col gap-2">
        <h1 class="text-2xl font-black text-slate-900 dark:text-white">Ops! Página não encontrada</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">
          O link que você seguiu pode estar quebrado ou a página foi removida.
        </p>
      </div>
      <div class="flex justify-center mt-2">
        <Button href="/" variant="primary" size="md">
          Voltar para a Home
        </Button>
      </div>
    </div>
  </div>
</BaseLayout>
