---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import ArticleToc from '../components/blog/ArticleToc.astro';
import Breadcrumb from '../components/seo/Breadcrumb.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { buildBlogPostingSchema, buildHowToSchema } from '../lib/seo';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string | Date;
    updated?: string | Date;
    author: string;
    category: string;
    keywords: string[];
    cover?: string;
    steps?: string[];
  };
  slug: string;
  headings?: { depth: number; slug: string; text: string }[];
  relatedPosts?: any[];
  serviceLink?: { href: string; label: string };
}

const { frontmatter, slug, headings, relatedPosts, serviceLink } = Astro.props;

const pubDate = new Date(frontmatter.pubDate);
const updated = frontmatter.updated ? new Date(frontmatter.updated) : undefined;

const blogPostingSchema = buildBlogPostingSchema({
  slug,
  title: frontmatter.title,
  description: frontmatter.description,
  pubDate,
  updated,
  author: frontmatter.author,
  cover: frontmatter.cover
});

const isHowTo = slug.startsWith('como-');
const howToSchema = isHowTo && frontmatter.steps
  ? buildHowToSchema(frontmatter.title, frontmatter.steps)
  : null;

const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog' },
  { name: frontmatter.title, href: `/blog/${slug}` }
];
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} image={frontmatter.cover} type="article">
  <!-- Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-1.5 z-50 bg-slate-200/50 dark:bg-slate-800/50">
    <div id="progress-bar" class="h-full bg-cyan-500 w-0 transition-all duration-150"></div>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const progressBar = document.getElementById('progress-bar');
      if (!progressBar) return;

      const updateProgress = () => {
        const scrollTotal = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        if (scrollTotal <= 0) return;
        const scrollFraction = window.scrollY / scrollTotal;
        progressBar.style.width = `${Math.min(100, Math.max(0, scrollFraction * 100))}%`;
      };

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    });
  </script>

  <!-- Schema Injections -->
  <JsonLd schema={blogPostingSchema} />
  {howToSchema && <JsonLd schema={howToSchema} />}

  <!--
    Blog post layout: 2-column grid on lg+ (TOC sticky on the left, article on the right).
    The TOC sits OUTSIDE the article body — it is a sibling, not a child.
    On mobile (<lg) the TOC is hidden; users can navigate via the top header + scroll.
  -->
  <div class="lg:grid lg:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[18rem_minmax(0,1fr)] lg:gap-10 xl:gap-14 px-6 lg:px-10 py-8 md:py-12">
    {headings && <ArticleToc headings={headings} />}

    <article class="min-w-0 max-w-3xl mx-auto lg:mx-0 w-full">
      <!-- Breadcrumbs -->
      <Breadcrumb customItems={breadcrumbItems} />

      <!-- Post Header -->
      <header class="flex flex-col gap-6 py-6 border-b border-slate-200/10 dark:border-slate-900 mb-8">
        <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-wider text-cyan-500">
          <span>{frontmatter.category}</span>
          <span class="w-1.5 h-1.5 rounded-full bg-slate-400 dark:bg-slate-700"></span>
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          {updated && (
            <>
              <span class="w-1.5 h-1.5 rounded-full bg-slate-400 dark:bg-slate-700"></span>
              <span class="text-slate-500 dark:text-slate-400 normal-case tracking-normal">
                Atualizado em {updated.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
              </span>
            </>
          )}
        </div>

        <h1 class="text-3xl md:text-5xl font-black tracking-tight leading-tight text-slate-900 dark:text-white">
          {frontmatter.title}
        </h1>

        <div class="flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
          <span>Por <strong class="text-slate-700 dark:text-slate-200">{frontmatter.author}</strong></span>
        </div>
      </header>

      <!-- Post Cover Image -->
      {frontmatter.cover && (
        <div class="mb-10 rounded-2xl overflow-hidden border border-slate-200/10 dark:border-slate-900 max-h-[450px]">
          <Image src={frontmatter.cover} alt="" width={800} height={450} class="w-full h-full object-cover" aria-hidden="true" />
        </div>
      )}

      <!-- Post Content (MDX Slot) -->
      <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-cyan-500 hover:prose-a:text-cyan-600 dark:prose-headings:text-white prose-p:leading-relaxed prose-li:my-1 prose-img:rounded-xl prose-img:border prose-img:border-slate-200/10 dark:prose-img:border-slate-900">
        <slot />
      </div>

      <!-- Service CTA -->
      {serviceLink && (
        <div class="mt-12 p-6 rounded-2xl border border-cyber-200 dark:border-cyber-900 bg-gradient-to-br from-cyber-50 to-white dark:from-cyber-950/30 dark:to-slate-900">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="flex-1">
              <h3 class="font-bold text-slate-900 dark:text-white text-lg mb-1">
                Precisa de {serviceLink.label}?
              </h3>
              <p class="text-sm text-slate-700 dark:text-slate-300">
                Fale com a Suitplus e solicite um orçamento personalizado.
              </p>
            </div>
            <div class="flex gap-3 shrink-0">
              <a
                href={serviceLink.href}
                class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cyber-600 hover:bg-cyber-700 text-white text-sm font-semibold rounded-lg transition active:scale-95"
              >
                Saiba Mais
                <svg class="w-4 h-4"><use href="/icons/sprite.svg#icon-arrow-right" /></svg>
              </a>
              <a
                href={`https://wa.me/5513996603357?text=${encodeURIComponent('Olá! Gostaria de saber mais sobre ' + serviceLink.label + '.')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition active:scale-95"
              >
                WhatsApp
                <svg class="w-4 h-4"><use href="/icons/sprite.svg#icon-whatsapp-logo" /></svg>
              </a>
            </div>
          </div>
        </div>
      )}

      <!-- Related Posts -->
      {relatedPosts && relatedPosts.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">
            Artigos Relacionados
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <a
                href={`/blog/${related.id}`}
                class="group block border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30 rounded-xl overflow-hidden hover:border-cyber-300 dark:hover:border-cyber-700 transition-colors"
              >
                {related.data.cover && (
                  <div class="h-40 overflow-hidden">
                    <Image
                      src={related.data.cover}
                      alt=""
                      width={400}
                      height={225}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      aria-hidden="true"
                    />
                  </div>
                )}
                <div class="p-4">
                  <div class="flex items-center gap-2 text-xs mb-2">
                    <span class="text-cyber-500 font-semibold uppercase tracking-wider">{related.data.category}</span>
                    <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-600"></span>
                    <time datetime={related.data.pubDate.toISOString()} class="text-slate-500 dark:text-slate-400 text-xs font-medium">
                      {new Date(related.data.pubDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </time>
                  </div>
                  <h3 class="font-bold text-slate-900 dark:text-white text-sm leading-snug group-hover:text-cyber-500 transition-colors line-clamp-2">
                    {related.data.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </div>
</BaseLayout>
