---
interface Props {
  class?: string;
  [key: string]: any;
}
const { class: className = '', ...rest } = Astro.props;
---

<div 
  class:list={[
    "bg-white dark:bg-neutral-900/60 border border-neutral-200 dark:border-neutral-800/60 p-6 rounded-2xl shadow-sm hover:border-neutral-300 dark:hover:border-neutral-700/60 transition-colors duration-200", 
    className
  ]} 
  {...rest}
>
  <slot />
</div>
