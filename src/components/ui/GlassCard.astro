---
interface Props {
  class?: string;
  [key: string]: any;
}
const { class: className = '', ...rest } = Astro.props;
---

<div 
  class:list={[
    "glass-surface transition-all duration-300", 
    className
  ]} 
  {...rest}
>
  <slot />
</div>

<style>
  /* Base fallback (no glass support, mobile, or reduced transparency) */
  .glass-surface {
    background-color: var(--color-white);
  }
  :global(html.dark) .glass-surface {
    background-color: var(--color-neutral-900);
  }

  /* Apply glassmorphism on desktop when transparency preference is no-preference */
  @media (min-width: 769px) {
    @media (prefers-reduced-transparency: no-preference) {
      @supports (backdrop-filter: blur(12px)) or (-webkit-backdrop-filter: blur(12px)) {
        .glass-surface {
          background-color: rgba(255, 255, 255, 0.6);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
        }
        :global(html.dark) .glass-surface {
          background-color: rgba(255, 255, 255, 0.03);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
        }
      }
    }
  }
</style>
