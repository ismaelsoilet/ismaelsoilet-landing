---
import Button from './Button.astro';
import Honeypot from './Honeypot.astro';
import { site } from '../../content/site';
---

<form id="contact-form" data-webhook={site.webhook.contact} class="flex flex-col gap-6 w-full max-w-lg mx-auto" novalidate>
  <!-- Honeypot anti-spam field -->
  <Honeypot />

  <!-- Form Fields -->
  <div class="flex flex-col gap-1.5">
    <label for="name" class="text-sm font-bold text-neutral-700 dark:text-neutral-300">Nome Completo</label>
    <input 
      type="text" 
      id="name" 
      name="name" 
      required 
      placeholder="Seu nome completo" 
      class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 text-neutral-900 dark:text-white placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-cyber-500 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="organization" class="text-sm font-bold text-neutral-700 dark:text-neutral-300">Organização ou Empresa</label>
    <input 
      type="text" 
      id="organization" 
      name="organization" 
      required 
      minlength="2"
      placeholder="Pode ser prefeitura, empresa, clínica ou instituição" 
      class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 text-neutral-900 dark:text-white placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-cyber-500 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="email" class="text-sm font-bold text-neutral-700 dark:text-neutral-300">E-mail Corporativo</label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required 
      placeholder="seu.nome@empresa.com" 
      class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 text-neutral-900 dark:text-white placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-cyber-500 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="phone" class="text-sm font-bold text-neutral-700 dark:text-neutral-300">Telefone / WhatsApp</label>
    <input 
      type="text" 
      inputmode="numeric"
      id="phone" 
      name="phone" 
      required 
      placeholder="(00) 00000-0000" 
      class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 text-neutral-900 dark:text-white placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-cyber-500 transition"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label for="message" class="text-sm font-bold text-neutral-700 dark:text-neutral-300">Como podemos ajudar?</label>
    <textarea 
      id="message" 
      name="message" 
      rows="4" 
      required 
      placeholder="Escreva sua mensagem aqui..." 
      class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 text-neutral-900 dark:text-white placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-cyber-500 transition resize-y"
    ></textarea>
  </div>

  <!-- Status messages -->
  <div id="status-success" aria-live="polite" class="hidden text-sm font-semibold text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 p-4 rounded-lg"></div>
  <div id="status-error" aria-live="assertive" class="hidden text-sm font-semibold text-rose-600 dark:text-rose-400 bg-rose-500/10 border border-rose-500/20 p-4 rounded-lg"></div>

  <!-- Submit Button -->
  <Button type="submit" variant="cyber" size="lg" class="w-full">
    Enviar Mensagem
  </Button>
</form>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form');
    if (!form) return;
    
    const webhookUrl = form.dataset.webhook;
    const phoneInput = form.querySelector('#phone') as HTMLInputElement | null;
    const successEl = document.getElementById('status-success');
    const errorEl = document.getElementById('status-error');
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    // Apply phone mask (vanilla JS, no external dependency)
    if (phoneInput) {
      phoneInput.addEventListener('input', () => {
        let value = phoneInput.value.replace(/\D/g, '');
        if (value.length > 11) value = value.slice(0, 11);
        if (value.length <= 2) {
          phoneInput.value = value;
        } else if (value.length <= 7) {
          phoneInput.value = `(${value.slice(0,2)}) ${value.slice(2)}`;
        } else {
          phoneInput.value = `(${value.slice(0,2)}) ${value.slice(2,7)}-${value.slice(7)}`;
        }
      });
    }

    // Handle submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset status elements
      if(successEl) { successEl.classList.add('hidden'); successEl.textContent = ''; }
      if(errorEl) { errorEl.classList.add('hidden'); errorEl.textContent = ''; }

      // Validate html5 constraints
      if (!form.checkValidity() && errorEl) {
        errorEl.textContent = 'Por favor, preencha todos os campos obrigatórios corretamente.';
        errorEl.classList.remove('hidden');
        return;
      }

      const formData = new FormData(form);
      
      // Honeypot check
      const username = formData.get('username') as string;
      if (username && username.trim() !== '') {
        console.warn('Silent abort: spambot detected.');
        if(successEl) {
          successEl.textContent = 'Mensagem enviada com sucesso!';
          successEl.classList.remove('hidden');
        }
        form.reset();
        return;
      }

      // Prepare payload to match N8N webhook legacy schema
      const payload = {
        Nome_Completo: formData.get('name'),
        organizacao_orgao: formData.get('organization') || 'Não Informado',
        melhor_email: formData.get('email'),
        celular: formData.get('phone'),
        mensagem: formData.get('message'),
        origem_lead: window.location.hostname,
        submittedAt: new Date().toISOString()
      };

      // Disable button & fields
      if(submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
      }

      try {
        if (!webhookUrl) throw new Error('Webhook URL não configurada.');
        
        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          if(successEl) {
            successEl.textContent = 'Mensagem enviada com sucesso! Entraremos em contato em breve.';
            successEl.classList.remove('hidden');
          }
          form.reset();
        } else {
          throw new Error('Falha no envio da mensagem.');
        }
      } catch (err) {
        if(errorEl) {
          errorEl.textContent = 'Erro ao enviar a mensagem. Por favor, tente novamente ou entre em contato diretamente.';
          errorEl.classList.remove('hidden');
        }
      } finally {
        // Re-enable button
        if(submitBtn) {
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    });
  });
</script>
