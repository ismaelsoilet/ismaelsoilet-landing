---
import { site } from '../../content/site';

interface Props {
  customItems?: { name: string; href: string }[];
}

const { customItems } = Astro.props;

// Automatically parse the current pathname to generate breadcrumbs if not provided custom
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);

const items = customItems || [
  { name: 'Home', href: '/' },
  ...segments.map((segment, index) => {
    const href = '/' + segments.slice(0, index + 1).join('/');
    const name = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
    return { name, href };
  })
];
---

<nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 py-3">
  {items.map((item, index) => {
    const isLast = index === items.length - 1;
    return (
      <div class="flex items-center gap-2">
        {index > 0 && (
          <svg class="w-3 h-3 text-slate-300 dark:text-slate-700" aria-hidden="true">
            <use href="/icons/sprite.svg#icon-caret-right" />
          </svg>
        )}
        {isLast ? (
          <span class="text-slate-900 dark:text-slate-100 font-semibold" aria-current="page">
            {item.name}
          </span>
        ) : (
          <a href={item.href} class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">
            {item.name}
          </a>
        )}
      </div>
    );
  })}
</nav>
