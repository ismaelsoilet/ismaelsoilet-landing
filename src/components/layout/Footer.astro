---
import { site } from '../../content/site';
import pkg from '../../../package.json';

const astroVersion = pkg.dependencies.astro?.replace(/[\^~]/g, '') || '5.0';
const tailwindVersion = pkg.dependencies.tailwindcss?.replace(/[\^~]/g, '') || '4.0';
const siteVersion = pkg.version;
---

<footer class="w-full bg-slate-50 dark:bg-slate-950 border-t border-slate-200/10 dark:border-slate-900 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-16 grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
    <!-- Brand column -->
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <img src="/logo.svg" alt="" class="w-6 h-6" aria-hidden="true" />
        <span class="font-bold text-lg text-slate-900 dark:text-white">{site.org.name}</span>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
        {site.org.description}
      </p>
      <!-- Social networks -->
      <div class="flex gap-4 text-slate-400 mt-2">
        {site.social.linkedin && (
          <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition" aria-label="LinkedIn">
            <svg class="w-5 h-5"><use href="/icons/sprite.svg#icon-linkedin-logo" /></svg>
          </a>
        )}
        {site.social.instagram && (
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition" aria-label="Instagram">
            <svg class="w-5 h-5"><use href="/icons/sprite.svg#icon-instagram-logo" /></svg>
          </a>
        )}
        {site.social.github && (
          <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition" aria-label="GitHub">
            <svg class="w-5 h-5"><use href="/icons/sprite.svg#icon-github-logo" /></svg>
          </a>
        )}
        {site.social.facebook && (
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition" aria-label="Facebook">
            <svg class="w-5 h-5"><use href="/icons/sprite.svg#icon-facebook-logo" /></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Navigation links -->
    <div class="flex flex-col gap-4">
      <h3 class="font-semibold text-slate-950 dark:text-white text-sm uppercase tracking-wider">Mapa do Site</h3>
      <nav class="flex flex-col gap-2.5 text-sm text-slate-600 dark:text-slate-400">
        <a href="/#about" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Sobre</a>
        <a href="/#impact" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Impacto</a>
        <a href="/#projects" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Cases</a>
        <a href="/#timeline" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Trajetória</a>
        <a href="/#skills" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Skills</a>
        <a href="/blog" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Blog</a>
      </nav>
    </div>

    <!-- Legal & Resources column -->
    <div class="flex flex-col gap-4">
      <div>
        <h3 class="font-semibold text-slate-950 dark:text-white text-sm uppercase tracking-wider mb-3">Legal</h3>
        <nav class="flex flex-col gap-2.5 text-sm text-slate-600 dark:text-slate-400">
          <a href="/privacidade" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Política de Privacidade</a>
          <a href="/termos" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Termos de Uso</a>
        </nav>
      </div>
      <div>
        <h3 class="font-semibold text-slate-950 dark:text-white text-sm uppercase tracking-wider mb-3">Recursos</h3>
        <nav class="flex flex-col gap-2.5 text-sm text-slate-600 dark:text-slate-400">
          <a href="/components" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Visual Catalog</a>
          <a href="/quickstart" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Quickstart Guide</a>
        </nav>
      </div>
    </div>

    <!-- Contact column -->
    <div class="flex flex-col gap-4">
      <h3 class="font-semibold text-slate-950 dark:text-white text-sm uppercase tracking-wider">Contato</h3>
      <ul class="flex flex-col gap-2.5 text-sm text-slate-600 dark:text-slate-400">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-cyber-500 dark:text-cyber-400"><use href="/icons/sprite.svg#icon-file-text" /></svg>
          <span>{site.contact.email}</span>
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-cyber-500 dark:text-cyber-400"><use href="/icons/sprite.svg#icon-whatsapp-logo" /></svg>
          <span>{site.contact.phone}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-6 border-t border-slate-200/5 dark:border-slate-900 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
    <span>&copy; {new Date().getFullYear()} {site.org.name}. Todos os direitos reservados.</span>
    <span>Versão {siteVersion} | Feito com Astro {astroVersion} &amp; Tailwind v{tailwindVersion}</span>
  </div>
</footer>
