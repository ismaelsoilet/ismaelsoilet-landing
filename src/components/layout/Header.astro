---
import { site } from '../../content/site';
---

<header class="w-full border-b border-neutral-200/10 dark:border-neutral-900 bg-white/70 dark:bg-neutral-950/70 backdrop-blur-md sticky top-0 z-40 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-6 h-20 flex justify-between items-center">
    <!-- Brand logo -->
    <a href="/" class="flex items-center gap-3 active:scale-95 transition" aria-label="Voltar para home">
      <img src="/logo.svg" alt="" class="w-7 h-7" aria-hidden="true" />
      <span class="font-bold text-xl tracking-tight bg-gradient-to-r from-cyber-400 to-primary-500 bg-clip-text text-transparent">
        {site.org.name}
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden md:flex gap-8 text-sm font-medium text-neutral-600 dark:text-neutral-400">
      <a href="/#about" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Sobre</a>
      <a href="/#impact" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Impacto</a>
      <a href="/#projects" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Cases</a>
      <a href="/#timeline" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Trajetória</a>
      <a href="/#skills" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Skills</a>
      <a href="/blog" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Blog</a>
      <a href="/#contact" class="hover:text-cyber-500 dark:hover:text-cyber-400 transition">Contato</a>
    </nav>

    <!-- Toolbar: Theme Toggle & Mobile Trigger -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle Button -->
      <button id="theme-toggle" class="p-2.5 border border-neutral-200/20 dark:border-neutral-800/80 rounded-lg text-neutral-600 dark:text-neutral-400 hover:text-cyber-500 dark:hover:text-cyber-400 hover:bg-neutral-100 dark:hover:bg-neutral-900/50 transition active:scale-95" aria-label="Alternar tema">
        <!-- Sun Icon (shown in dark mode) -->
        <svg class="w-5 h-5 hidden dark:block"><use href="/icons/sprite.svg#icon-sun" /></svg>
        <!-- Moon Icon (shown in light mode) -->
        <svg class="w-5 h-5 block dark:hidden"><use href="/icons/sprite.svg#icon-moon" /></svg>
      </button>

      <!-- Mobile Menu Trigger -->
      <button id="mobile-menu-trigger" class="p-2.5 md:hidden border border-neutral-200/20 dark:border-neutral-800/80 rounded-lg text-neutral-600 dark:text-neutral-400 hover:text-cyber-500 dark:hover:text-cyber-400 hover:bg-neutral-100 dark:hover:bg-neutral-900/50 transition active:scale-95" aria-label="Abrir menu">
        <svg class="w-5 h-5"><use href="/icons/sprite.svg#icon-list" /></svg>
      </button>
    </div>
  </div>
</header>

<script>
  import { setTheme, getTheme } from '../../lib/theme';

  document.addEventListener('astro:page-load', () => {
    const toggleBtn = document.getElementById('theme-toggle');

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const current = getTheme();
        const next = current === 'dark' ? 'light' : 'dark';
        setTheme(next);
        
        // Dispatch custom event to let other components react (e.g. charts, islands)
        window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: next } }));
      });
    }
  });
</script>
